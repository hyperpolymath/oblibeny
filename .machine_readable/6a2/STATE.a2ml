# STATE.a2ml — Project state checkpoint
# Converted from STATE.scm (schema-version 1.0); originally created 2026-01-03

[metadata]
project = "oblibeny"
version = "0.0.1"
schema-version = "1.0"
created = "2026-01-03"
last-updated = "2026-06-12"
repo = "github.com/hyperpolymath/oblibeny"
status = "active-development"

[project-context]
name = "oblibeny"
tagline = "Secure edge language for reversibility and accountability"
# Recalibrated 2026-06-12. The earlier 100% / "production-ready" figure
# predated the CI gate: PR #51 found the Idris2 ABI proofs were
# non-compiling stubs (one believe_me-masked FALSE theorem) and a
# type-safety hole in the constrained-form checker. Those are now fixed
# and CI-gated, but the crypto FFI cannot link in CI (liboqs system dep)
# and obli-pkg's verify path is an explicit MVP stub (TODO(security)).
completion-percentage = 85
phase = "active-development"
implementation-language = "OCaml + Zig"
tech-stack = "OCaml, Zig, Idris2"
target-domains = "security-critical, edge-computing, cryptography"

[related-repos]
# Sibling repositories in the oblibeny toolchain.
obli-transpiler-framework = "Transpiler to other languages (11 Rust files)"
obli-fs = "Filesystem features (WASM)"
obli-riscv-dev-kit = "RISC-V development tooling"
obli-ssg = "Static site generator"
nextgen-languages-oblibeny = "OUTDATED - embedded snapshot, 0 OCaml files"

[current-position]
phase = "active-development"
overall-completion = 85
# Measured 2026-06-12 on origin/main (git ls-files / wc -l):
loc-ocaml = 4304
loc-zig = 1047
loc-idris = 554
files-tracked = 170
ocaml-files = 20
zig-files = 5
idris-files = 3
vscode-extension = true
ci-gate = "build + 27-test conformance suite + Idris2 ABI proof type-check + escape-hatch guard (ci.yml, since PR #52)"

# ---------------------------------------------------------------------------
# Recent work landed on main since the previous STATE checkpoint
# (git log 2026-02-07..2026-06-12; PR numbers from merge subjects).
# ---------------------------------------------------------------------------

[recent-work]
pr-48 = "feat(types): echo[A,B] residue type added end-to-end (AST, lexer, parser, typecheck, eval, constrained_check, static_analyzer) + full docs + governance fixes (2026-06-02)"
pr-51 = "Real Idris2 ABI proofs: discharged believe_me debt (one masked theorem was FALSE as written), total proofs of installReversible + doubleInstallIdempotent, no funext axiom; fixed Eq/Neq type-safety (progress) hole in constrained-form checker"
pr-52 = "CI gate added (ci.yml): OCaml build + conformance suite, Idris2 0.7.0 proof type-check (src/abi/oblibeny-abi.ipkg), escape-hatch guard (believe_me/postulate/assert_total/partial/holes); re-pinned stale Hypatia + Scorecard reusable SHAs"
pr-53 = "Scorecard startup_failure root-caused (job-level permissions dropped contents:read) and fixed; instant-sync presence-gated on FARM_DISPATCH_TOKEN"
pr-54 = "Removed 6 orphaned submodule gitlinks (no .gitmodules, no upstream repos)"
pr-55 = "Echo-reversibility linear discipline: non-copyable echoes must be consumed exactly once (overwrite/drop discipline); conformance suite grew to 27 tests"
pr-56 = "Metadata migrated .machine_readable/*.scm to 6a2/*.a2ml (estate convention); Zig FFI compile-fixes for Zig 0.13 (build.zig LazyPath idiom, obli-pkg.zig fixes); CodeQL cron weekly to monthly"
pr-57-58 = "Dependabot: codeql-action 4.36.0->4.36.2, actions/checkout 6.0.2->6.0.3"

# ---------------------------------------------------------------------------
# Current blockers (live list, 2026-06-12). The [blockers.*] tables further
# down are the HISTORICAL 60%-checkpoint list, retained for provenance.
# ---------------------------------------------------------------------------

[blockers-current]
liboqs-link-dep = "Zig FFI compiles under Zig 0.13 but the link step fails on the absent liboqs system library (external dependency; ffi/zig/build.zig linkSystemLibrary(\"oqs\")). CI does not build the Zig FFI."
obli-pkg-verify-stub = "obli-pkg signature-verify path is an explicit MVP stub with a placeholder payload — TODO(security) at ffi/zig/src/obli-pkg.zig:377; the canonical signed payload still needs deriving"
farm-dispatch-token = "FARM_DISPATCH_TOKEN secret expired/invalid (found in PR #52); instant-sync is presence-gated since #53, but propagation stays off until the maintainer rotates the secret"
claude-md-stale-refs = ".claude/CLAUDE.md still references .machine_readable/*.scm files removed by the #56 migration; file is guardrail-blocked, needs a maintainer edit"

[next-actions]
n01 = "Rotate FARM_DISPATCH_TOKEN (maintainer; gh secret set FARM_DISPATCH_TOKEN)"
n02 = "Derive the real signed payload for obli-pkg verify (closes TODO(security))"
n03 = "Decide CI strategy for the Zig FFI: build liboqs from source in CI or vendor a pinned build"
n04 = "Maintainer edit of .claude/CLAUDE.md: .scm references -> 6a2/*.a2ml"


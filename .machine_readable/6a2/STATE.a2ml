# ---------------------------------------------------------------------------
# Blockers and issues — historical, from the 60%-completion checkpoint.
# All are resolved at the 100% production-ready state; retained for provenance.
# ---------------------------------------------------------------------------

[blockers.code-fragmentation]
tier = "critical"
severity = "critical"
impact = "Development scattered across 6 repos"
description = "Examples in boinc-boinc/examples/, transpiler separate, toolchain repos scattered"
affected-repos = "boinc-boinc/examples/crypto-xor.obl, security-audit/repos/oblibeny-playground/, obli-transpiler-framework/, obli-fs/"

[blockers.crypto-integration-incomplete]
tier = "critical"
severity = "high"
impact = "Cannot verify security guarantees without complete crypto stack"
description = "Zig FFI has 3 files but crypto integration incomplete"

[blockers.no-package-manager]
tier = "high"
severity = "medium"
impact = "Cannot manage dependencies"
description = "obli-pkg started but incomplete"

[blockers.no-editor-integration]
tier = "high"
severity = "medium"
impact = "Poor developer experience"
description = "Missing LSP server"

[blockers.documentation-minimal]
tier = "medium"
severity = "low"
impact = "Difficult for new users to understand"
description = "Only BUILD-LOG.md, needs comprehensive docs"


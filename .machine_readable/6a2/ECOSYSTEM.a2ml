# SPDX-License-Identifier: MPL-2.0
# ECOSYSTEM.a2ml — Ecosystem position
# Converted from ECOSYSTEM.scm

[metadata]
project = "oblibeny"
version = "1.0"
ecosystem = "hyperpolymath"
name = "oblibeny"
type = "edge-language / constrained-form compiler"
purpose = "Turing-incomplete constrained form for reversible, accountable computation on secure edge devices"

[position]
type = "component"
category = "programming-language"
subcategory = "edge / safety-critical / formally-verified"

[position.unique-value]
# Why oblibeny is distinct in the ecosystem.
v01 = "Dual-form: factory (Turing-complete, compile-time) + constrained (Turing-incomplete, runtime)"
v02 = "First-class echo type: structured, proof-relevant residue of irreversible collapse"
v03 = "Full reversibility: every constrained-form operation has a defined inverse"
v04 = "Accountability trace: every operation produces an immutable audit trail"
v05 = "Static resource bounds: termination, memory, call depth all computable at compile time"

[position.target-deployment]
d01 = "Hardware Security Modules (HSMs)"
d02 = "Secure enclaves (SGX, TrustZone)"
d03 = "Smart cards / tamper-resistant hardware"
d04 = "IoT / IIoT edge nodes with accountability requirements"
d05 = "Safety-critical embedded systems"

# ---------------------------------------------------------------------------
# Related projects — repo, language, relationship, and (where recorded) the
# interface doc and SPEC section that wires oblibeny to each.
# ---------------------------------------------------------------------------

[related-projects.echo-types]
repo = "github.com/hyperpolymath/echo-types"
language = "Agda"
relationship = "type-theory-source"
description = "Constructive Agda formalisation of echo types: loss that is not total erasure (Echo f y := Sigma (x : A), f x == y). Oblibeny's echo[A, B] type is the constrained-form realisation of this fibre/residue."
interface-doc = "docs/specs/echo-6a2.adoc"
spec-section = "SPEC §6.a.2"

[related-projects.echotypes-jl]
repo = "github.com/hyperpolymath/EchoTypes.jl"
language = "Julia"
relationship = "executable-model"
description = "Finite-domain executable companion to echo-types (a runnable model, not a proof). Oblibeny's echo_visible / echo_witness projections follow this finite-domain reading."
interface-doc = "docs/specs/echo-6a2.adoc"
spec-section = "SPEC §6.a.2"

[related-projects.svalinn]
repo = "github.com/hyperpolymath/svalinn"
language = "Rust"
relationship = "deployment-runtime"
description = "Edge gateway for verified containers; Oblibeny programs deploy via the Svalinn/Vordr verified container stack."

[related-projects.maa-protocol]
repo = "external: maa-protocol/SPEC.scm"
language = "Specification"
relationship = "external-interface"
description = "Mutually-Assured-Accountability protocol; Oblibeny traces can be committed to the MAA ledger for external verification."
spec-section = "SPEC §6.a.1"

[related-projects.absolute-zero]
repo = "external: absolute-zero/SPEC.scm"
language = "Specification"
relationship = "external-interface"
description = "Zero-knowledge proof system for Oblibeny traces; supports proving properties of traces without revealing content."
spec-section = "SPEC §6.a.3"

# ---------------------------------------------------------------------------
# Sibling repositories in the oblibeny toolchain (from STATE.scm related-repos;
# mirrored here for ecosystem completeness).
# ---------------------------------------------------------------------------

[related-repos]
obli-transpiler-framework = "Transpiler to other languages (11 Rust files)"
obli-fs = "Filesystem features (WASM)"
obli-riscv-dev-kit = "RISC-V development tooling"
obli-ssg = "Static site generator"
nextgen-languages-oblibeny = "OUTDATED - embedded snapshot, 0 OCaml files"

# ---------------------------------------------------------------------------
# What this is — scope statements from ECOSYSTEM.scm.
# ---------------------------------------------------------------------------

[what-this-is]
w01 = "A programming language where the runtime form (constrained form) is Turing-incomplete by design"
w02 = "A compiler from constrained-form source (.obl files) to an evaluated trace-producing runtime"
w03 = "A factory language: the factory form generates constrained-form programs at compile time"
w04 = "A type system with first-class echo types (structured irreversible collapse residues)"
w05 = "An accountability framework: every runtime operation produces an immutable audit trail"
w06 = "A foundation for formally-verified edge software"

[what-this-is-not]
n01 = "A general-purpose programming language"
n02 = "A systems programming language (use Rust for systems)"
n03 = "A proof assistant (use Agda/Coq/Lean for proofs; echo-types is the proof companion)"
n04 = "A scripting language"
n05 = "A language for unbounded computation"
n06 = "A JavaScript/TypeScript/Go/Python alternative (see CLAUDE.md language policy)"

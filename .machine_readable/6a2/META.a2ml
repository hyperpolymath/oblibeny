# SPDX-License-Identifier: MPL-2.0
# META.a2ml — Project meta-information
# Converted from META.scm

[metadata]
project = "oblibeny"
author = "Jonathan D.A. Jewell <jonathan.jewell@gmail.com>"
license = "MPL-2.0"
standard = "RSR 2026"

# ---------------------------------------------------------------------------
# Architecture decisions — each carries the original decision date.
# ---------------------------------------------------------------------------

[architecture-decisions.echo-type-two-param]
date = "2026-06-02"
decision = "echo[A, B] is parameterised by source domain A and visible codomain B, not by specific map f and value y"
rationale = "Oblibeny has no dependent types; the Agda fibre Echo f y := Sigma (x:A), f x = y cannot be transcribed literally. Two-param form follows the EchoTypes.jl finite-domain reading: a constrained-form residue storing the surviving observation alongside a retained witness."
alternatives-rejected = "Single-param echo[B] (loses source type); dependent echo f y (requires dependent sums, out of scope for f0)"

[architecture-decisions.echo-affinity-content-sensitive]
date = "2026-06-02"
decision = "echo[A, B] is affine iff A or B is non-copyable; both-copyable echoes are unrestricted"
rationale = "Echo should not make copyable data non-copyable by magic. If both sides are copyable, duplicating the echo smuggles in no extra authority, heap state, trace state, or hidden capability. For non-copyable contents, affine consumption is essential to prevent echo[A,B] degenerating into an unrestricted product A*B that can be freely destructured."
alternatives-rejected = "All echoes affine (gratuitously restrictive for primitive copyable data, breaks constrained-form usability); no affinity at all (allows non-copyable resource duplication)"

[architecture-decisions.echo-not-reversible]
date = "2026-06-02"
decision = "echo[A, B] does not participate in incr/decr/swap balancing and is not reversible"
rationale = "Echo is the type-level dual of the reversible core: it models structured loss. Adding reversibility to echo would contradict its purpose — the echo exists precisely because the original operation was not reversible."
alternatives-rejected = "Reversible echo (contradicts the semantic intent)"

[architecture-decisions.constrained-form-no-rhino]
date = "2026-01-01"
decision = "The constrained form is intentionally small, analysable, and hostile to unwanted expressivity"
rationale = "Security boundary: keep the entrance too small for the rhino. Every new feature must be checked against this principle. Echo was admitted because it adds a new observable type (residue / proof-relevant loss) without adding recursion, first-class functions, new control flow, or new patterns of non-copyable resource access."
alternatives-rejected = "More expressive constrained form (widens attack surface and makes analysis harder)"

# ---------------------------------------------------------------------------
# Development practices.
# ---------------------------------------------------------------------------

[practices.code-style]
ocaml-style = "Standard OCaml; no ppx magic in core lib; pattern-match exhaustively"
no-comments = "Default to writing no comments; only when the WHY is non-obvious"
spdx-headers = "SPDX-License-Identifier and SPDX-FileCopyrightText on all source files"

[practices.security]
principle = "Defense in depth"
crypto = "Post-quantum: Dilithium5, SPHINCS+, Kyber1024; classical fallback Ed25519"
no-md5-sha1 = "Use SHA256+ only"
no-hardcoded-secrets = "Always"

[practices.testing]
framework = "Alcotest"
golden-path = "dune test -- runs full conformance suite"
conformance = "test/conformance_test.ml is the authoritative conformance gate"
new-types = "Every new type must have: typecheck test, constrained-check test, eval test, type-error rejection test, safety/no-rhino test"

[practices.versioning]
scheme = "SemVer"

[practices.documentation]
primary-format = "AsciiDoc (.adoc) for long-form; Markdown (.md) for conventional files (CHANGELOG, README-plain)"
spec = "SPEC.core.scm is the authoritative formal specification"
alignment = "docs/echo-alignment.md is the decisions ledger for echo-types ecosystem alignment"
contractiles = "docs/CONTRACTILES.adoc is the behavioral contracts document"

[practices.branching]
stable = "main for stable releases"
feature = "feature branches named claude/<description>-<id> for AI-driven PRs"
merge-strategy = "squash merge to main; keep PR as unit of change"

# ---------------------------------------------------------------------------
# Design rationale — narrative notes on the core architecture.
# ---------------------------------------------------------------------------

[design-rationale]
dual-form-architecture = "The dual-form architecture (Turing-complete factory + Turing-incomplete constrained) is the core insight: the factory form generates constrained programs at compile time. The factory form never ships to the edge device — only its output does. This means you get the expressivity of a full language for metaprogramming without compromising the formal guarantees of the runtime."
echo-as-accountability-dual = "The echo type is the accountability dual of the trace type: where Trace records what happened in reversible computation, echo[A,B] captures the residue of irreversible collapse. Together, Trace (reversible accountability) and echo (irreversible-but-witnessed loss) cover the full spectrum of computation on constrained devices."
no-proof-in-constrained-form = "The constrained form deliberately has no proof terms, no dependent types, and no identity types. The echo type demonstrates what is achievable without them: proof-relevant structure (the witness) without a proof obligation (f x = y). This is the finite-domain reading: executable, not axiomatic."

#
# AGENTIC.a2ml — AI agent interaction patterns
# Converted from AGENTIC.scm. Defines how AI agents operate in this repository.

[metadata]
version = "2.0.0"
last-updated = "2026-06-02"

# ---------------------------------------------------------------------------
# Claude Code configuration.
# ---------------------------------------------------------------------------

[claude-code]
model = "claude-opus-4-8"
tools = "read, edit, write, bash, grep, glob, agent"
permissions = "read-all"

[claude-code.first-run-protocol]
step-1 = "Read .machine_readable/STATE.scm for current project state"
step-2 = "Read .machine_readable/META.scm for architecture decisions"
step-3 = "Read ANCHOR.scope-arrest.2026-01-01.Jewell.scm for identity/scope rules"
step-4 = "Run: dune build && dune test (golden path)"
step-5 = "Check .machine_readable/PLAYBOOK.scm for operational procedures"

# ---------------------------------------------------------------------------
# Working patterns.
# ---------------------------------------------------------------------------

[patterns]
code-review = "thorough"
refactoring = "conservative — do not refactor beyond the task"
testing = "comprehensive — new types require typecheck/eval/constrained/rejection/safety tests"
documentation = "always update STATE.scm, CHANGELOG.md, and relevant docs when adding features"
commits = "one logical change per commit; conventional commits format"

# ---------------------------------------------------------------------------
# Constraints — what agents must/must not do.
# ---------------------------------------------------------------------------

[agent-constraints]
languages = ""
banned = "typescript, go, python, makefile, node, npm, bun, kotlin, swift"
required-on-new-files = "SPDX-License-Identifier: MPL-2.0, SPDX-FileCopyrightText"
no-new-types-without = "constrained_check.ml traversal, typecheck.ml rules, eval.ml VT variant, conformance tests"

# ---------------------------------------------------------------------------
# Echo-type handling — agent rules specific to the echo[A,B] type.
# ---------------------------------------------------------------------------

[echo-type-handling]
affinity-rule = "echo[A,B] is affine iff A or B is non-copyable; is_copyable(echo[A,B]) = is_copyable(A) && is_copyable(B)"
no-rhino-check = "Every echo extension must be checked: does it add recursion? new control flow? new non-copyable resource patterns? If yes, reject unless explicitly in scope."

[echo-type-handling.when-modifying-echo]
step-1 = "Check is_copyable logic in lib/typecheck.ml covers new type constructors"
step-2 = "Check constrained_check.ml recurses into echo expressions"
step-3 = "Check static_analyzer.ml sizes echo memory as witness + visible"
step-4 = "Run dune test -- grep echo to verify all echo conformance tests pass"
step-5 = "Update examples/echo-types.obl if surface syntax changes"
step-6 = "Update docs/specs/echo-6a2.adoc if the external interface contract changes"
step-7 = "Update docs/CONTRACTILES.adoc E-series and A-series if affinity rules change"

# ---------------------------------------------------------------------------
# CI-failure handling — how agents diagnose specific governance check failures.
# ---------------------------------------------------------------------------

[ci-failure-handling]
governance-trusted-base = "If 'Trusted-base reduction policy' fails: check docs/proof-debt.md exists and follows the schema at hyperpolymath/standards/docs/TRUSTED-BASE-REDUCTION-POLICY.adoc. Scan for believe_me / soundness-escape-hatches in Idris2 files. Triage in proof-debt.md."
codeql-actions-scan = "The CodeQL workflow scans GitHub Actions workflows (language: actions), not JS/TS. If it fails, check .github/workflows/codeql.yml has language: actions and build-mode: none."
governance-licence = "All new source files must have SPDX-License-Identifier: MPL-2.0 and SPDX-FileCopyrightText headers."
governance-language-policy = "No TypeScript, Go, Python, Makefile, Node, npm, bun, Kotlin, Swift. See CLAUDE.md for full policy."

# ---------------------------------------------------------------------------
# Gitbot automation — conventions for automated PR flows.
# ---------------------------------------------------------------------------

[gitbot-automation]
pr-naming-convention = "claude/<short-description>-<random-id> for AI-driven feature branches"
pr-creation = "Always create as draft PR; include Summary, Test plan, and session link in body"
ci-circular-dependency-resolution = "When two governance-fix PRs have circular CI dependencies (each fixes the other's one failure), merge both branches into the feature branch before merging to main. See 2026-06-02 echo-type merge as reference."
stale-branch-cleanup = "After merging to main, delete all claude/* branches that were subsumed. Use: git push origin --delete <branch>"
state-scm-update = "After any significant feature merge, add a session-history entry to .machine_readable/STATE.scm with date, focus, achievements, and metrics."

[gitbot-automation.documentation-checklist]
d01 = "README.adoc — add new type/feature to Unique Features section"
d02 = "CHANGELOG.md — add entry under [Unreleased]"
d03 = "SPEC.core.scm — add to relevant sections (types, ops, conformance, external-interfaces, examples)"
d04 = ".machine_readable/STATE.scm — add session-history entry"
d05 = ".machine_readable/META.scm — add architecture decision if significant"
d06 = ".machine_readable/ECOSYSTEM.scm — update if ecosystem relationships change"
d07 = "docs/LANGUAGE-SPEC.md — add type/feature section"
d08 = "docs/TUTORIAL.md — add tutorial section"
d09 = "docs/CONTRACTILES.adoc — add contracts for new type (E-series, A-series, etc.)"
d10 = "docs/specs/echo-6a2.adoc — update if echo interface contract changes"

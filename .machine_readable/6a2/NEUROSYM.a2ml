[metadata]
version = "1.0.0"

# ---------------------------------------------------------------------------
# Symbolic layer — deductive, formally verified, Scheme-typed.
# ---------------------------------------------------------------------------

[symbolic-layer]
type = "scheme"
reasoning = "deductive"
verification = "formal"

# ---------------------------------------------------------------------------
# Neural layer — no embeddings, no fine-tuning.
# ---------------------------------------------------------------------------

[neural-layer]
embeddings = false
fine-tuning = false

# ---------------------------------------------------------------------------
